{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npx tsc --noEmit)",
      "Bash(timeout 8 npm run dev)",
      "Bash(netstat -ano)",
      "Bash(findstr \":3000\")",
      "Bash(tasklist /FI \"PID eq 61984\")",
      "Bash(tasklist)",
      "Bash(wmic process where ProcessId=61984 get CommandLine)",
      "Bash(taskkill /PID 61984 /F)",
      "Bash(cmd /c \"taskkill /PID 61984 /F\")",
      "Bash(cmd /c \"taskkill /PID 61984 /F 2>&1\")",
      "Bash(powershell -Command \"Stop-Process -Id 61984 -Force\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(powershell -Command \"Get-NetTCPConnection -LocalPort 3000 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess | Select-Object -First 1\")",
      "Bash(powershell -Command \"Stop-Process -Id 38152 -Force\")",
      "Bash(powershell -Command \"Get-Process -Id 92572 | Select-Object Name, Id, Path\")",
      "Bash(powershell -Command \"Get-Process -Id 92572 | Select-Object -ExpandProperty CommandLine\")",
      "Bash(powershell -Command \"\\(Get-WmiObject Win32_Process -Filter \"\"ProcessId = 92572\"\"\\).CommandLine\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5173)",
      "Bash(powershell -Command \"Get-NetTCPConnection -LocalPort 5173 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess | Select-Object -First 1\")",
      "Bash(mv stitch editor)",
      "Bash(rm -rf node_modules package-lock.json package.json)",
      "Bash(taskkill /F /IM node.exe)",
      "Bash(lsof +D stitch/)",
      "Bash(fuser stitch/)",
      "Bash(powershell.exe -Command \"Get-Process | Where-Object { $_.MainWindowTitle -like ''*stitch*'' -or $_.ProcessName -eq ''node'' } | Select-Object Id, ProcessName, MainWindowTitle\")",
      "Bash(powershell.exe -Command \"Get-Process node -ErrorAction SilentlyContinue | Stop-Process -Force; Write-Host ''killed''\")",
      "Bash(powershell.exe -Command \"Rename-Item -Path ''stitch'' -NewName ''editor'' -ErrorAction Stop; Write-Host ''renamed ok''\")",
      "Bash(wait)",
      "Bash(echo \"exit: $?\")",
      "Bash(npm run build)",
      "Bash(node -e \":*)",
      "Bash(npm run dev)",
      "Bash(python -c \":*)",
      "Bash(pip install pdfplumber -q)",
      "Bash(npm install html-to-image jspdf --save)"
    ]
  }
}
